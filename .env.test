# Config for linters and tests

# Python
PYTHONPATH=src
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Domains
ALLOWED_HOSTS=.testserver
ROOT_DOMAIN=testserver
SESSION_COOKIE_DOMAIN=.testserver
DJANGO_SETTINGS_MODULE = "ludamus.edges.settings"

# Auth0
AUTH0_CLIENT_ID=test-auth0-client-id
AUTH0_CLIENT_SECRET=test-auth0-client-secret
AUTH0_DOMAIN=auth0.example.com

# Database
DB_NAME=:memory:
USE_POSTGRES=false

# Static files
GIT_COMMIT_SHA=1

# Membership API
MEMBERSHIP_API_BASE_URL=https://memberhip-test.example.com/api/v1/endpoint
MEMBERSHIP_API_TOKEN=membership-test-token

# Other
DEBUG=false
ENV=local
SECRET_KEY=test-secret-key

"\n"
"                            This will create a copy of \"%(venue_name)s\" "
"including all areas and spaces.\n"
"                        "
msgstr ""
"\n"
"                            Spowoduje to utworzenie kopii \"%(venue_name)s\" "
"wraz ze wszystkimi strefami i przestrzeniami.\n"
"                        "

#: src/ludamus/templates/panel/venue-duplicate.html:44
msgid "e.g., Main Hall (Copy)"
msgstr "np. Hala główna (Kopia)"


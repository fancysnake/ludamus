msgstr "Składanie zgłoszeń nie jest obecnie aktywne dla tego wydarzenia."

msgid "Please select a category first."
msgstr "Najpierw wybierz kategorię."

msgid "Invalid category."
msgstr "Nieprawidłowa kategoria."

msgid "Please select a category."
msgstr "Wybierz kategorię."

msgid "Please select at least one time slot."
msgstr "Wybierz przynajmniej jeden blok czasowy."

msgid "Please select at least one track."
msgstr "Wybierz przynajmniej jedną ścieżkę."

msgid "Missing session details. Please start over."
msgstr "Brak szczegółów punktu programu. Zacznij od nowa."

msgid "Please wait before submitting another proposal."
msgstr "Poczekaj chwilę przed przesłaniem kolejnego zgłoszenia."


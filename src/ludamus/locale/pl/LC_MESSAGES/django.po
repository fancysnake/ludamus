msgstr "Czas rozpoczęcia jest wymagany."

msgid "End time is required."
msgstr "Czas zakończenia jest wymagany."

msgid "Category name is too long (max 255 characters)."
msgstr "Nazwa kategorii jest za długa (max 255 znaków)."

msgid "Category name is required."
msgstr "Nazwa kategorii jest wymagana."

msgid "Minimum participants limit cannot exceed maximum."
msgstr "Minimalna liczba uczestników nie może przekraczać maksymalnej."


msgstr "PEGI 16"

msgid "PEGI 18"
msgstr "PEGI 18"

msgid "Select the appropriate age rating for this session"
msgstr "Wybierz odpowiednią kategorię wiekową dla tego punktu programu"

msgid "Enter session title"
msgstr "Tytuł punktu programu"

msgid "Describe your session"
msgstr "Opisz swój punkt programu"

msgid "What should participants bring or know?"
msgstr "Co uczestnicy powinni przynieść lub wiedzieć?"

msgid "What materials or space do you need?"
msgstr "Jakie materiały lub przestrzeń potrzebujesz?"

msgid "Select a space..."
msgstr "Wybierz przestrzeń..."

msgid "Space"
msgstr "Przestrzeń"

msgid "Select the space where this session will take place"
msgstr "Wybierz przestrzeń, gdzie odbędzie się ten punkt programu"

msgid "Time slot"
msgstr "Konflikt czasowy"

msgid "Select the time slot for this session"
msgstr "Nie jesteś na liście oczekujących dla tego punktu programu."

msgid "Select a time slot..."
msgstr "Wybierz blok czasowy..."

msgid "This field is required."
msgstr "To pole jest wymagane."

msgid "Invalid space selection."
msgstr "Nieprawidłowy wybór sali."

msgid "There is already a session scheduled at this space and time."
msgstr "Ten użytkownik jest już zapisany na ten punkt programu."

msgid "Sphere not found"
msgstr "Sfera nie została znaleziona."

msgid "Invalid authentication request: missing state parameter"
msgstr "Nieprawidłowe żądanie uwierzytelnienia: brak parametru stanu"

msgid "Authentication session expired. Please try again."
msgstr "Sesja uwierzytelnienia wygasła. Spróbuj ponownie."

msgid "Invalid authentication state"
msgstr "Nieprawidłowy stan uwierzytelnienia"

msgid "Welcome!"
msgstr "Witaj!"

msgid "Please complete your profile."
msgstr "Proszę uzupełnić profil."

msgid "Authentication failed"
msgstr "Uwierzytelnienie nie powiodło się"

msgid "You have been successfully logged out."
msgstr "Zostałeś pomyślnie wylogowany."

msgid "Invalid redirect URL."
msgstr "Nieprawidłowy address URL przekierowania."

msgid "Invalid domain for redirect."
msgstr "Nieprawidłowa domena do przekierowania."

msgid ""
"This email address is already in use. Please use a different email address."
msgstr "Ten adres email został już użyty na innym koncie."

msgid "Profile updated successfully!"
msgstr "Profil został zaktualizowany!"

msgid "Please correct the errors below."
msgstr "Proszę poprawić błędy poniżej."

#, python-format
msgid "You can only have up to %(max)s connected users."
msgstr "Możesz mieć maksymalnie %(max)s powiązanych użytkowników."

msgid "Connected user added successfully!"
msgstr "Powiązana osoba została dodana!"

msgid "Connected user updated successfully!"
msgstr "Powiązana osoba została zaktualizowana!"

msgid "Connected user deleted successfully."
msgstr "Powiązana osoba została usunięta."

msgid "Avatar preference updated successfully!"
msgstr "Preferencja awatara została zaktualizowana!"

msgid "yourself"
msgstr "siebie"

msgid "Session not found."
msgstr "Punkt programu nie został znaleziony."

msgid "No enrollment configuration is available for this session."
msgstr "Brak dostępnej konfiguracji zapisów dla tego punktu programu."

msgid "Email address is required for enrollment in this session."
msgstr "Do zapisu na ten punkt programu wymagany jest adres email."

msgid ""
"Enrollment access permission is required for this session. Please contact "
"the organizers to obtain access."
msgstr ""
"Do zapisu na tę sesję wymagane jest uprawnienie dostępu. Skontaktuj się z "
"organizatorami, aby uzyskać dostęp."

msgid "Please review the enrollment options below."
msgstr "Proszę przejrzeć opcje zapisu poniżej."

msgid "promoted from waiting list"
msgstr "przeniesiony z listy oczekujących"

msgid "session host"
msgstr "twórca punktu programu"

msgid "time conflict"
msgstr "konflikt czasowy"

#, python-brace-format
msgid "Enrolled: {}"
msgstr "Zapisani: {}"

#, python-brace-format
msgid "Added to waiting list: {}"
msgstr "Dodani do listy oczekujących: {}"

#, python-brace-format
msgid "Cancelled: {}"
msgstr "Anulowani: {}"

#, python-brace-format
msgid "Skipped (already enrolled or conflicts): {}"
msgstr "Pominięci (już zapisani lub konflikty): {}"

#, python-brace-format
msgid ""
"Not enough spots available. {} spots requested, {} available. Please use "
"waiting list for some users."
msgstr ""
"Brak wystarczającej liczby miejsc. {} miejsc potrzebnych, {} dostępnych. "
"Użyj listy oczekujących dla niektórych użytkowników."

msgid "Please select at least one user to enroll."
msgstr "Wybierz przynajmniej jednego użytkownika do zapisu."

#, python-brace-format
msgid "Session proposal '{}' submitted successfully!"
msgstr "Zgłoszenie punktu programu '{}' zostało pomyślnie przesłane!"

msgid "Event not found."
msgstr "Festiwal nie został znaleziony."

msgid "Proposal submission is not currently active for this event."
msgstr "Składanie zgłoszeń nie jest obecnie aktywne dla tego wydarzenia."

msgid ""
"No proposal category configured for this event. Please contact the "
"organizers."
msgstr ""
"Brak skonfigurowanej kategorii zgłoszeń dla tego wydarzenia. Skontaktuj się "
"z organizatorami."

msgid "Proposal not found."
msgstr "Zgłoszenie nie zostało znalezione."

msgid "This proposal has already been accepted."
msgstr "To zgłoszenie zostało już zaakceptowane."

msgid "You don't have permission to accept proposals for this event."
msgstr "Nie masz uprawnień do akceptowania propozycji dla tego wydarzenia."

#, python-brace-format
msgid "Proposal '{}' has been accepted and added to the agenda."
msgstr "Zgłoszenie '{}' zostało zaakceptowane i dodane do programu."

msgid "No spaces configured for this event. Please create spaces first."
msgstr ""
"Brak skonfigurowanych przestrzeni dla tego wydarzenia. Najpierw utwórz "
"przestrzenie."

msgid ""
"No time slots configured for this event. Please create time slots first."
msgstr ""
"Brak skonfigurowanych przedziałów czasowych dla tego wydarzenia. Najpierw "
"utwórz przedziały czasowe."

msgid "Anonymous enrollment is not available for this event."
msgstr "Anonimowy zapis nie jest dostępny dla tego wydarzenia."

msgid "Anonymous enrollment is not active."
msgstr "Anonimowy zapis nie jest aktywny."

msgid "Anonymous enrollment session is not valid for this site."
msgstr "Anonimowa sesja zapisu nie jest ważna dla tej strony."

msgid "Anonymous session expired."
msgstr "Anonimowa sesja wygasła."

msgid "Anonymous user not found."
msgstr "Anonimowy użytkownik nie znaleziony."

msgid "Name is required."
msgstr "Imię jest wymagane."

#, python-format
msgid "Successfully cancelled enrollment in session: %(title)s"
msgstr "Pomyślnie anulowano zapis na sesję: %(title)s"

msgid "No enrollment found to cancel."
msgstr "Nie znaleziono zapisu do anulowania."

msgid ""
"Cannot enroll: You are already enrolled in another session that conflicts "
"with this time slot."
msgstr ""
"Nie można się zapisać: Jesteś już zapisany na inną sesję, która koliduje z "
"tym terminem."

#, python-format
msgid "Session is full. You have been added to the waiting list for: %(title)s"
msgstr "Sesja jest pełna. Zostałeś dodany do listy oczekujących na: %(title)s"

#, python-format
msgid "Successfully enrolled in session: %(title)s"
msgstr "Pomyślnie zapisano na sesję: %(title)s"

msgid "Please enter a code."
msgstr "Proszę wprowadzić kod."

msgid "Invalid code. Please check and try again."
msgstr "Nieprawidłowy kod. Sprawdź i spróbuj ponownie."

msgid "No enrollments found for this code."
msgstr "Nie znaleziono zapisów dla tego kodu."

msgid "Code loaded successfully. You can now manage your enrollments."
msgstr "Kod załadowany pomyślnie. Możesz teraz zarządzać swoimi zapisami."

msgid "Event name is too long (max 255 characters)."
msgstr "Nazwa wydarzenia jest za długa (max 255 znaków)."

msgid "Event name is required."
msgstr "Nazwa wydarzenia jest wymagana."

msgid "Category name is too long (max 255 characters)."
msgstr "Nazwa kategorii jest za długa (max 255 znaków)."

msgid "Category name is required."
msgstr "Nazwa kategorii jest wymagana."

msgid "Text"
msgstr "Tekst"

msgid "Select"
msgstr "Wybór"

msgid "Field name is too long (max 255 characters)."
msgstr "Nazwa pola jest za długa (max 255 znaków)."

msgid "Field name is required."
msgstr "Nazwa pola jest wymagana."

msgid "One option per line (for Select fields only)."
msgstr "Jedna opcja na linię (tylko dla pól typu Wybór)."

msgid "Allow selecting multiple options (for Select fields only)."

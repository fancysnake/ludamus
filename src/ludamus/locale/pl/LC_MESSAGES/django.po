msgstr "Powiązana osoba została dodana!"

msgid "Connected user updated successfully!"
msgstr "Powiązana osoba została zaktualizowana!"

msgid "Connected user deleted successfully."
msgstr "Powiązana osoba została usunięta."

msgid "Avatar preference updated successfully!"
msgstr "Preferencja awatara została zaktualizowana!"

msgid "yourself"
msgstr "siebie"

msgid "Session not found."
msgstr "Punkt programu nie został znaleziony."

msgid "No enrollment configuration is available for this session."
msgstr "Brak dostępnej konfiguracji zapisów dla tego punktu programu."

#, fuzzy
#| msgid "Email address is required for enrollment i this session."
msgid "Email address is required for enrollment in this session."
msgstr "Do zapisu na ten punkt programu wymagany jest adres email."

msgid ""
"Enrollment access permission is required for this session. Please contact "
"the organizers to obtain access."
msgstr ""
"Do zapisu na tę sesję wymagane jest uprawnienie dostępu. Skontaktuj się z "
"organizatorami, aby uzyskać dostęp."

msgid "Please review the enrollment options below."
msgstr "Proszę przejrzeć opcje zapisu poniżej."

msgid "promoted from waiting list"
msgstr "przeniesiony z listy oczekujących"


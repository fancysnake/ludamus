msgstr ""
"Brak skonfigurowanych przestrzeni dla tego wydarzenia. Najpierw utwórz "
"przestrzenie."

msgid ""
"No time slots configured for this event. Please create time slots first."
msgstr ""
"Brak skonfigurowanych przedziałów czasowych dla tego wydarzenia. Najpierw "
"utwórz przedziały czasowe."

msgid "Event not found."
msgstr "Festiwal nie został znaleziony."

msgid "Anonymous enrollment is not available for this event."
msgstr "Anonimowy zapis nie jest dostępny dla tego wydarzenia."


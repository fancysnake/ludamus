msgstr "Nieprawidłowa domena do przekierowania."

msgid ""
"This email address is already in use. Please use a different email address."
msgstr "Ten adres email został już użyty na innym koncie."

msgid "Profile updated successfully!"
msgstr "Profil został zaktualizowany!"

msgid "Please correct the errors below."
msgstr "Proszę poprawić błędy poniżej."

#, python-format
msgid "You can only have up to %(max)s connected users."
msgstr "Możesz mieć maksymalnie %(max)s powiązanych użytkowników."


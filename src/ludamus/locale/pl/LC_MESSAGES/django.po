msgstr "Anonimowy zapis nie jest aktywny."

msgid "Anonymous enrollment session is not valid for this site."
msgstr "Anonimowa sesja zapisu nie jest ważna dla tej strony."

msgid "Anonymous session expired."
msgstr "Anonimowa sesja wygasła."

msgid "Anonymous user not found."
msgstr "Anonimowy użytkownik nie znaleziony."

#, python-format

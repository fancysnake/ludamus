msgstr "Zwykły zapis"

#: src/ludamus/adapters/web/django/forms.py:150
msgid "Move to waiting list"
msgstr "Dodani do listy oczekujących: {}"

#: src/ludamus/adapters/web/django/forms.py:157
msgid "Enroll (if spots available)"
msgstr "Zapisz się (jeśli są miejsca)"


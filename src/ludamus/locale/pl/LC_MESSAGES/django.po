msgstr "Pomyślnie anulowano zapis na sesję: %(title)s"

msgid "No enrollment found to cancel."
msgstr "Nie znaleziono zapisu do anulowania."

msgid ""
"Cannot enroll: You are already enrolled in another session that conflicts "
"with this time slot."
msgstr ""
"Nie można się zapisać: Jesteś już zapisany na inną sesję, która koliduje z "
"tym terminem."

#, python-format
msgid "Session is full. You have been added to the waiting list for: %(title)s"
msgstr "Sesja jest pełna. Zostałeś dodany do listy oczekujących na: %(title)s"

#, python-format
msgid "Successfully enrolled in session: %(title)s"
msgstr "Pomyślnie zapisano na sesję: %(title)s"

msgid "Name is required."
msgstr "Imię jest wymagane."

msgid "Please enter a code."
msgstr "Proszę wprowadzić kod."

msgid "Invalid code. Please check and try again."
msgstr "Nieprawidłowy kod. Sprawdź i spróbuj ponownie."

msgid "No enrollments found for this code."
msgstr "Nie znaleziono zapisów dla tego kodu."

msgid "Code loaded successfully. You can now manage your enrollments."
msgstr "Kod załadowany pomyślnie. Możesz teraz zarządzać swoimi zapisami."

msgid "Contact email"
msgstr "Email kontaktowy"

msgid "Max participants"
msgstr "Maks. uczestników"

msgid "0 = no limit"
msgstr "0 = bez limitu"

msgid "Title"
msgstr "Tytuł"

msgid "Description"
msgstr "Opis"

msgid "Minimum age"
msgstr "Minimalny wiek"

msgid "0 = no age restriction"
msgstr "0 = brak ograniczenia wiekowego"

msgid "Presenter name"
msgstr "Nazwa prowadzącego"

msgid "Duration"
msgstr "Czas trwania"


#!/usr/bin/env bash

set -euo pipefail

case "${AUTH0_DOMAIN:-}" in
  *local*) ;;
  *) exec tail -f /dev/null ;;
esac

cert_dir="$HOME/.simulacrum/certs"
if [ ! -f "$cert_dir/localhost.pem" ] || [ ! -f "$cert_dir/localhost-key.pem" ]; then
  echo "[auth0] missing $cert_dir/localhost{.pem,-key.pem}; not starting simulator" >&2
  exec tail -f /dev/null
fi

if lsof -ti :4400 >/dev/null 2>&1; then
  echo "[auth0] killing stale process on :4400" >&2
  lsof -ti :4400 | xargs kill -9 2>/dev/null || true
  sleep 1
fi

src/ludamus/client/node_modules/.bin/portless alias auth0 4400 >/dev/null 2>&1 || true
exec src/ludamus/client/node_modules/.bin/auth0-simulator
